7Lorebook\uff06\u7b97\u5716\u5206\u4eab\u5340\uff0c\u4ee5\u53ca\u5275\u4f5c\u5206\u4eab\u4ea4\u6d41\u3002  </p>","tags":["\u4f3a\u670d\u5668","\u4ecb\u7d39"]},{"location":"server/channels/#_7","title":"\u4e3b\u984c\u96c6\u4e2d","text":"<p>\u91dd\u5c0d\u7279\u5b9a\u5e73\u53f0\u7684\u8a0e\u8ad6\u8207\u4ea4\u6d41\uff0c\u76ee\u524d\uff082025/9/13\uff09\u4e3b\u984c\u6709\uff1aSillyTavern\u3001JanitorAI\u3001Kindroid\u3001\u5b98\u7db2RP\u3001\u537f\u537f\u6211\u6211\u3001\u5e73\u53f0\u7d9c\u5408\u3001LLM\uff06API\uff06\u63d0\u793a\u8a5e\u3002  </p>","tags":["\u4f3a\u670d\u5668","\u4ecb\u7d39"]},{"location":"server/channels/#_8","title":"\u8a9e\u97f3\u5ba4","text":"<p>\u4f9b\u958b\u9ea5\u9592\u804a\uff0c\u4e5f\u6709Jockie Music\u53ef\u4f9b\u639b\u6a5f\u807d\u97f3\u6a02\u3002  </p>","tags":["\u4f3a\u670d\u5668","\u4ecb\u7d39"]},{"location":"server/rules/","title":"\u3010\u4f3a\u670d\u5668\u6307\u5357-\u5165\u5e97\u9808\u77e5\u3011","text":"","tags":["\u4f3a\u670d\u5668","\u4ecb\u7d39"]},{"location":"server/rules/#_1","title":"\u672a\u6210\u5e74\u53ef\u4ee5\u52a0\u5165\u55ce\uff1f","text":"<p>\u4e0d\u884c\u3002  </p>","tags":["\u4f3a\u670d\u5668","\u4ecb\u7d39"]},{"location":"server/rules/#discord","title":"\u6211\u6c92\u7528\u904e/\u4e0d\u719f\u6089Discord\u4e5f\u53ef\u4ee5\u52a0\u5165\u55ce\uff1f","text":"<p>\u7576\u7136\u53ef\u4ee5\uff0c\u4f3a\u670d\u5668\u5167\u4e5f\u5305\u542bDiscord\u7684\u4f7f\u7528\u6559\u5b78\uff0c\u6b61\u8fce\u52a0\u5165\u4e26\u4e00\u8d77\u8a0e\u8ad6\uff01  </p>","tags":["\u4f3a\u670d\u5668","\u4ecb\u7d39"]},{"location":"server/rules/#_2","title":"\u52a0\u5165\u4f3a\u670d\u5668\u9700\u8981\u6ce8\u610f\u4ec0\u9ebc\uff1f","text":"<p>\u8acb\u52d9\u5fc5\u8a73\u95b1\u898f\u5247\uff01 \u4f3a\u670d\u5668\u5167\u6709\u300c\u4e00\u822c\u9a57\u8b49\u300d\u8207\u300c\u6210\u5e74\u9a57\u8b49\u300d\u3002\u82e5\u60f3\u9577\u671f\u5f85\u5728\u4f3a\u670d\u5668\u5167\u5247\u9700\u8981\u9032\u884c\u4e00\u822c\u9a57\u8b49\uff0c\u800c\u6210\u5e74\u9a57\u8b49\u70ba\u97